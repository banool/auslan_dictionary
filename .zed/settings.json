// Project Zed settings — keep editor-on-save formatting in lockstep with the
// pre-commit hook + CI (all use `dart format`).
{
  "format_on_save": "on",
  "languages": {
    "Dart": { "formatter": "language_server" },
    // Never reformat Markdown on save — prose stays long-line, soft-wrapped.
    "Markdown": { "format_on_save": "off" }
  }
}
