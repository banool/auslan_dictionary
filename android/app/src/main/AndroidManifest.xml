<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.banool.auslan_dictionary">
    <!-- The Facebook SDK injects the advertising-id permission, but the app
         never uses advertising IDs (and Facebook sign-in is currently
         switched off entirely) — the Play Console declaration says so, and
         Play rejects uploads carrying the permission. Strip it at
         manifest-merge time. -->
    <uses-permission
        android:name="com.google.android.gms.permission.AD_ID"
        tools:node="remove" />
    <application
        android:name="${applicationName}"
        android:label="Auslan Dictionary"
        android:usesCleartextTraffic="true"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name="io.flutter.embedding.android.FlutterActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <!-- Displays an Android View that continues showing the launch screen
                 Drawable until Flutter paints its first frame, then this splash
                 screen fades out. A splash screen is useful to avoid any visual
                 gap between the end of Android's launch screen and the painting of
                 Flutter's first frame. -->
            <meta-data
              android:name="io.flutter.embedding.android.SplashScreenDrawable"
              android:resource="@drawable/launch_background"
              />
            <!-- Disable Flutter's built-in deep-link handling. Deep links are
                 routed by the app_links package (DeepLinkHandler in
                 dictionarylib), which rewrites incoming share URLs to the
                 GoRouter `/share/:listId` location. If Flutter also handled
                 them it would hand the raw URI (e.g.
                 `auslan://share/<id>?invite=<tok>`) straight to GoRouter,
                 which has no matching route, throwing a GoException. -->
            <meta-data
              android:name="flutter_deeplinking_enabled"
              android:value="false"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Verified App Link for shared-list URLs. The matching
                 assetlinks.json is served at
                 https://share.auslandictionary.org/.well-known/assetlinks.json
                 by the static site in dictionarylib/lists/site/. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="share.auslandictionary.org"
                      android:pathPrefix="/l/" />
            </intent-filter>
            <!-- Custom-scheme fallback used by the landing-page JS when App
                 Link verification hasn't completed. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="auslan" android:host="share" />
            </intent-filter>
        </activity>
        <!-- Sign in with Apple — Android web flow. The package's
             SignInWithAppleCallback activity needs an App-Link intent
             filter pointing at the URL the Worker 302s to after Apple
             POSTs the form_post. Same host as the share-link landing
             pages (share.<dict>); a different path so it doesn't
             collide with the main activity's /l/* filter. -->
        <activity
            android:name="com.aboutyou.dart_packages.sign_in_with_apple.SignInWithAppleCallback"
            android:exported="true">
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="share.auslandictionary.org"
                      android:path="/apple-callback" />
            </intent-filter>
        </activity>
        <!-- Facebook Login (flutter_facebook_auth). FacebookAppID +
             ClientToken come from developers.facebook.com → My Apps →
             App ID. fb_login_protocol_scheme is "fb<APP_ID>". The
             values are provisioned in res/values/strings.xml. -->
        <meta-data android:name="com.facebook.sdk.ApplicationId"
            android:value="@string/facebook_app_id"/>
        <meta-data android:name="com.facebook.sdk.ClientToken"
            android:value="@string/facebook_client_token"/>
        <activity
            android:name="com.facebook.FacebookActivity"
            android:configChanges="keyboard|keyboardHidden|screenLayout|screenSize|orientation"
            android:label="@string/app_name" />
        <activity
            android:name="com.facebook.CustomTabActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="@string/fb_login_protocol_scheme" />
            </intent-filter>
        </activity>
        <!-- Microsoft sign-in (MSAL via msal_auth). The browser-delegated
             auth flow redirects back to msauth://<package>/<sig-hash>, which
             this BrowserTabActivity catches. One data element per signing
             key the app may run under so the redirect resolves in every
             build (generate with android/get-sha1.sh): the release/upload
             key and the local debug key are listed below. The hashes here
             are the RAW base64 SHA-1 of each cert — Android matches
             intent-filter paths against the percent-DECODED URI path, so
             the URL-encoded form (which is correct in main.dart and Azure)
             would never match here.
             NOTE: Play App Signing re-signs the uploaded artifact, so the
             store build runs under Google's app-signing key, NOT the upload
             key. Add that key's hash here (and in Azure) too; get its
             base64 SHA-1 from Play Console, App integrity, App signing key
             certificate. Keep in sync with microsoftAndroidRedirectUri in
             lib/main.dart and the Azure app registration. -->
        <activity
            android:name="com.microsoft.identity.client.BrowserTabActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- Play App Signing key (production / store builds) -->
                <data android:scheme="msauth"
                      android:host="com.banool.auslan_dictionary"
                      android:path="/tnPupvWBIsfs5VUhZbUCXxyL8/Q=" />
                <!-- release / upload key (locally-signed release builds) -->
                <data android:scheme="msauth"
                      android:host="com.banool.auslan_dictionary"
                      android:path="/uJIuQL8qD443LNaG3+5OF+zMYB4=" />
                <!-- local debug key -->
                <data android:scheme="msauth"
                      android:host="com.banool.auslan_dictionary"
                      android:path="/mLnUCgy8ygvZ+2jXJtHai/NmrCw=" />
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- MSAL browser-delegated auth needs network-state visibility. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <!-- Facebook SDK probes for the Facebook app. Required on Android
         11+ due to package visibility restrictions. -->
    <queries>
        <package android:name="com.facebook.katana" />
    </queries>
</manifest>
